{
    "main": "./workers/app.ts",
    "name": "counterscale",
    "compatibility_flags": [
        "nodejs_compat_v2"
    ],
    "compatibility_date": "2024-12-13",
    "assets": {
        "binding": "ASSETS",
        "directory": "./build/client"
    },
    "analytics_engine_datasets": [
        {
            "binding": "WEB_COUNTER_AE",
            "dataset": "metricsDataset"
        }
    ],
    "triggers": {
        "crons": [
            "0 2 * * *"
        ]
    },
    "vars": {
        "SYNC_ANALYTICS_URL": "https://www.simplepaystub.com/api/sync-analytics"
    }
}